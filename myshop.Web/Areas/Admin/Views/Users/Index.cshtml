@model IEnumerable<ApplicationUser>

@{
    ViewBag.PageTitle = "Users Management";
    ViewBag.CardTitle = "View Users";
}


<div>
    <a class="btn btn-primary" href="/Identity/Account/Register">Create New Users</a>
</div>

<br />
<table class="table table-hover" width="100%">
    <tr>
        <td>Name</td>
        <td>Email</td>
        <td>Phone Number</td>
        <td>Actions</td>
    </tr>
    @foreach(var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.Email</td>
            <td>@item.PhoneNumber</td>
            <td>
                @if (item.LockoutEnd != null && item.LockoutEnd > DateTime.UtcNow)
                {
                    <a class="btn btn-outline-danger btn-sm"  asp-action="LockUnlock" asp-route-id="@item.Id">
                        <i class="fas fa-lock"></i>
                    </a>
                }
                else
                {
                    <a class="btn btn-outline-success btn-sm"  asp-action="LockUnlock" asp-route-id="@item.Id">
                        <i class="fas fa-lock-open"></i>
                    </a>
                }

                <a class="btn btn-outline-danger btn-sm"  asp-action="Delete" asp-route-id="@item.Id">
                    <i class="bi bi-trash"></i> Delete
                </a>
            </td>
        </tr>
    }
</table>
