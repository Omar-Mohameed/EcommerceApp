@model IEnumerable<Category>

@{
    ViewBag.PageTitle = "Category Management";
    ViewBag.CardTitle = "View Categories";
}


<div>
    <a asp-action="Create" asp-controller="Category" class="btn btn-primary">Add Category</a>
</div>

<br />
<table class="table table-hover table-bordered" width="100%">
    <thead class="text-bold">
        <tr>
            <td>Name</td>
            <td>Description</td>
            <td>Date Created</td>
            <td>Actions</td>
        </tr>
    </thead>
    @foreach(var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@Html.Raw(item.Description)</td>
            <td>@item.CreatedTime</td>
            <td>
                <a class="btn btn-outline-warning btn-sm"  asp-action="Edit" asp-route-id="@item.Id">
                    <i class="bi bi-pencil-square"></i> Edit
                </a>
                <a class="btn btn-outline-danger btn-sm"  asp-action="Delete" asp-route-id="@item.Id">
                    <i class="bi bi-trash"></i> Delete
                </a>
            </td>
        </tr>
    }
</table>
