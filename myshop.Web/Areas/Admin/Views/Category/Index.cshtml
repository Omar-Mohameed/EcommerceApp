@model IEnumerable<Category>

@{
    ViewBag.PageTitle = "Category Management";
    ViewBag.CardTitle = "View Categories";
    Layout = "/Views/Shared/_Dashboard.cshtml";
}


<div>
    <a asp-action="Create" asp-controller="Category" class="btn btn-primary">Add Category</a>
</div>

<br />
<table class="table table-hover" width="100%">
    <tr>
        <td>Name</td>
        <td>Description</td>
        <td>Date Created</td>
        <td>Actions</td>
    </tr>
    @foreach(var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.Description</td>
            <td>@item.CreatedTime</td>
            <td>
                <a class="btn btn-outline-warning btn-sm"  asp-action="Edit" asp-route-id="@item.Id">
                    <i class="bi bi-pencil-square"></i> Edit
                </a>
                <a class="btn btn-outline-danger btn-sm"  asp-action="Delete" asp-route-id="@item.Id">
                    <i class="bi bi-trash"></i> Delete
                </a>
            </td>
        </tr>
    }
</table>
