@model Category
@{
    ViewBag.PageTitle = "Category Management";
    ViewBag.CardTitle = "Create Category";
}

<div class="row">
    <div class="col-md-4">
        <form method="post" asp-action="Create" asp-controller="Category">
            <div class="mb-3">
                <label asp-for="Name"></label>
                <input asp-for="Name" class="form-control"/>
                <span asp-validation-for="Name" class="text-danger"></span>

            </div>
            <div class="mb-3">
                <label asp-for="Description"></label>
                <textarea id="mytextarea" asp-for="Description" class="form-control" ></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>

            </div>
            <div class="mb-3">
                <button type="submit" class="btn btn-outline-primary">
                    <i class="bi bi-plus-lg"></i> Create
                </button>
                <a asp-action="Index" asp-controller="Category" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Back
                </a>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
    <script>
        tinymce.init({
            selector: '#mytextarea'
        });
    </script>
}
